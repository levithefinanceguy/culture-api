			/* Media & Text - Video */
.wp-block-media-text .wp-block-media-text__video {
	z-index: 2;
}

/* Downloadable Asset - Button Icon */
.c-card-downloadable-asset .wp-block-button__link svg {
	display: none;
}		</style>
