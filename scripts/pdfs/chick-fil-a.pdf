<body
	class="error404 wp-embed-responsive wp-theme-cfa wp-child-theme-cfa-us">
		<!-- Google Tag Manager (noscript) -->
	<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NXDPGM"
	height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
	<!-- End Google Tag Manager (noscript) -->
	
	<div id="page" class="site">
		<a class="skip-link screen-reader-text" href="#content">Skip to content</a>

		
<header id="masthead" class="c-site-header" role="banner">

	
<div class="c-site-header__top desktop" data-component-type="utility_nav">
	<div class="container">

		<button
			type="button"
			class="c-site-header__top--btn restaurants icon-pin"
			aria-expanded="false"
			aria-controls="restaurant-locator-dialog"
			data-a11y-dialog-show="restaurant-locator-dialog"
		>
			Find restaurants
		</button>
					<div class="c-site-header__top--account">
				
<a href="https://order.chick-fil-a.com/load-dot-com?myRewards=true"
	class="c-site-header__rewards icon-rewards hidden"
	data-wp-interactive="cfa-rewards-store"
	data-wp-init="actions.getRewards"
	data-wp-bind--href="state.rewardsUrl"
	data-wp-class--hidden="!state.rewards"
>
	<span
		data-wp-text="state.summaryText"
	></span>
</a>


<div
	class="c-site-header__top--account-buttons"
	data-wp-interactive="cfa-account-store"
	data-wp-init="callbacks.init"
>
	<div class="c-site-header__top--btn skeleton" data-wp-class--hidden="!state.isLoading"></div>
	<button
		class="c-site-header__top--btn account sign-in icon-account js-auth-cta"
		data-wp-class--visible="state.isSignInVisible"
		data-wp-class--hidden="!state.signInDesktopLabel.length"
		data-wp-class--hidden="!state.signInMobileLabel.length"
	>
		<span
			class="desktop"
			data-wp-text="state.signInDesktopLabel"
		>Sign in or join for rewards</span>
		<span
			class="mobile"
			data-wp-text="state.signInMobileLabel"
		>Sign in/Join</span>
	</button>

	<a href="http://order.chick-fil-a.com/load-dot-com?myAccount=true"
		class="c-site-header__top--btn account icon-account signed-in"
		data-wp-class--visible="state.isSignedIn"
		data-wp-class--hidden="!state.signOutLabel.length"
		data-wp-class--hidden="!state.signedInUrl.length"
		data-wp-class--hidden="state.isLoading"
		data-wp-bind--href="state.signedInUrl"
		data-wp-text="state.signedInLabel"
	>Account</a>
	<button
		class="c-site-header__top--btn account sign-out js-auth-cta"
		data-wp-class--visible="state.isSignedIn"
		data-wp-class--hidden="!state.signOutLabel.length"
		data-wp-class--hidden="!state.signedInUrl.length"
		data-wp-class--hidden="state.isLoading"
		data-wp-text="state.signOutLabel"
	>Sign out</button>
</div>


<button
	type="button"
	class="c-site-header__top--btn search icon-search js-header-search"
	aria-label="Search"
	aria-expanded="false"
	aria-controls="site-search-dialog"
	data-a11y-dialog-show="site-search-dialog"
></button>
			</div>
		
	</div>
</div>

	<div class="c-site-header__content js-header-content">
		<div class="container">

			
<button
	id="primary-toggle-menu"
	class="c-site-header__hamburger"
	aria-haspopup="true"
	aria-expanded="false"
	aria-controls="header-primary-menu"
	aria-label="Menu - open main menu"
	data-open-label="Menu - open main menu"
	data-close-label="Menu - close main menu"
>
	<span class="line"></span>
	<span class="line"></span>
	<span class="line"></span>
</button>
			
<div class="c-site-header__branding">

	<div class="c-site-logo">

		<a
			href="https://www.chick-fil-a.com"
			rel="home"
			aria-label="Chick-fil-A Home"
		>
			<img
				alt="Chick-fil-A"
				class="site-logo"
				decoding="async"
				loading="eager"
				fetchpriority="high"
				src="https://www.chick-fil-a.com/wp-content/uploads/sites/2/2025/04/Chick-fil-A-header-logo.svg"
				width="76"
				height="77"
			/>
		</a>

	</div>

</div>

			<div class="c-site-header__nav js-primary-mobile-drawer">
